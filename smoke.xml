<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Smoke suite — fast sanity check (4 tests, no data providers).
  Run with: mvn test -Dsurefire.suiteXmlFiles=smoke.xml
-->
<suite name="Smoke Suite" verbose="1" parallel="methods" thread-count="2">

    <listeners>
        <listener class-name="com.automation.listeners.ScreenshotListener"/>
        <listener class-name="com.automation.listeners.RetryAnnotationTransformer"/>
    </listeners>

    <test name="Smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.automation.tests.RegisterTest"/>
            <class name="com.automation.tests.NavigationTest"/>
        </classes>
    </test>

</suite>
